!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Saranya S — AI & Data Science Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<style>
  /* GLOBAL STYLES */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* LIGHT THEME VARIABLES */
    --bg: #fbfbf9;
    --bg-gradient: linear-gradient(135deg, #fbfbf9 0%, #f3f0e7 100%);
    --bg-accent: #f3f0e7;
    --text: #181715;
    --text-muted: #6e6760;
    --accent: #d85c43;
    --accent-secondary: #f0a37e;
    --accent-gradient: linear-gradient(135deg, #d85c43 0%, #f0a37e 100%);
    --accent-glow: rgba(216, 92, 67, 0.15);
    --card: #ffffff;
    --card-border: rgba(24, 23, 21, 0.08);
    --shadow: 0 10px 40px rgba(24, 23, 21, 0.04);
    --glow: none;
    --nav-bg: rgba(251, 251, 249, 0.85);
    --timeline-line: #f3f0e7;
    --badge-bg: #eaf7ed;
    --badge-text: #207235;
    --nav-h: 70px;
    --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  [data-theme="dark"] {
    /* DARK THEME VARIABLES (Default & Sleek) */
    --bg: #090c15;
    --bg-gradient: linear-gradient(135deg, #090c15 0%, #03050a 100%);
    --bg-accent: #111827;
    --text: #f3f4f6;
    --text-muted: #9ca3af;
    --accent: #38bdf8;
    --accent-secondary: #a855f7;
    --accent-gradient: linear-gradient(135deg, #38bdf8 0%, #a855f7 100%);
    --accent-glow: rgba(56, 189, 248, 0.25);
    --card: rgba(17, 25, 40, 0.65);
    --card-border: rgba(255, 255, 255, 0.08);
    --shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    --glow: 0 0 25px rgba(56, 189, 248, 0.15);
    --nav-bg: rgba(9, 12, 21, 0.85);
    --timeline-line: #1f2937;
    --badge-bg: rgba(56, 189, 248, 0.15);
    --badge-text: #38bdf8;
  }

  html {
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--accent) var(--bg-accent);
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg-accent); }
  ::-webkit-scrollbar-thumb {
    background: var(--accent);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent-secondary); }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg-gradient);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
    transition: var(--transition);
  }

  h1, h2, h3, h4, .nav-logo, .stat-num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    height: var(--nav-h);
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--card-border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 clamp(1.5rem, 6vw, 6rem);
    transition: var(--transition);
  }
  .nav-logo {
    font-size: 1.4rem;
    color: var(--text);
    text-decoration: none;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
    position: relative;
  }
  .nav-links { display: flex; gap: 2.25rem; list-style: none; align-items: center; }
  .nav-links a {
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    transition: color 0.2s;
    position: relative;
    padding: 0.25rem 0;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: 0; left: 0; width: 0; height: 2px;
    background: var(--accent-gradient);
    transition: width 0.3s ease;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a:hover::after { width: 100%; }

  .nav-actions { display: flex; align-items: center; gap: 1.5rem; }
  
  .nav-badge {
    font-size: 0.75rem;
    background: var(--badge-bg);
    color: var(--badge-text);
    padding: 6px 14px;
    border-radius: 30px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(56, 189, 248, 0.15);
  }
  .nav-badge::before {
    content: "";
    width: 8px; height: 8px;
    background: #10b981;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 10px #10b981;
    animation: pulse 1.8s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.9); opacity: 0.6; }
    50% { transform: scale(1.15); opacity: 1; }
    100% { transform: scale(0.9); opacity: 0.6; }
  }

  /* THEME TOGGLE BUTTON */
  .theme-toggle {
    background: none; border: none;
    cursor: pointer; padding: 8px;
    border-radius: 50%; width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--card-border);
    color: var(--text);
    background: var(--card);
    transition: var(--transition);
  }
  .theme-toggle:hover {
    transform: rotate(15deg) scale(1.05);
    box-shadow: var(--shadow);
    border-color: var(--accent);
  }
  .theme-toggle svg { width: 20px; height: 20px; fill: currentColor; }

  /* MOBILE NAVIGATION MENU */
  .menu-btn {
    display: none; background: none; border: none;
    cursor: pointer; color: var(--text); z-index: 1001;
    padding: 0.5rem;
  }
  .menu-btn svg { width: 24px; height: 24px; fill: currentColor; }
  
  .mobile-drawer {
    position: fixed; top: 0; right: -100%; width: 300px; height: 100vh;
    background: var(--bg);
    border-left: 1px solid var(--card-border);
    z-index: 999; padding: 6rem 2rem 2rem;
    display: flex; flex-direction: column; gap: 2rem;
    transition: right 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: var(--shadow);
    backdrop-filter: blur(20px);
  }
  .mobile-drawer.open { right: 0; }
  .mobile-drawer a {
    text-decoration: none; font-size: 1.15rem; font-weight: 600;
    color: var(--text-muted); transition: color 0.2s;
  }
  .mobile-drawer a:hover { color: var(--accent); }

  /* HERO SECTION */
  .hero {
    min-height: 100vh;
    padding: calc(var(--nav-h) + 3rem) clamp(1.5rem, 8vw, 8rem) 4rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 4rem;
    position: relative;
  }
  
  .hero-text { z-index: 2; position: relative; animation: fadeUp 0.8s cubic-bezier(0.25, 0.8, 0.25, 1) both; }
  .hero-text .section-label { margin-bottom: 1rem; }
  .hero-text h1 {
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    color: var(--text);
  }
  .hero-text h1 em {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: normal;
    position: relative;
    display: inline-block;
  }
  .hero-text p {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 520px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }
  .hero-btns { display: flex; gap: 1.25rem; flex-wrap: wrap; }
  
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: var(--transition);
    border: none;
    box-shadow: var(--shadow);
  }
  .btn-primary {
    background: var(--accent-gradient);
    color: #fff;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px var(--accent-glow);
  }
  .btn-outline {
    background: var(--card);
    color: var(--text);
    border: 1px solid var(--card-border);
  }
  .btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .hero-stats {
    display: flex; gap: clamp(1.5rem, 4vw, 3rem); margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--card-border);
  }
  .stat-item { text-align: left; }
  .stat-num {
    font-size: 2.25rem;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: block;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }

  .hero-img {
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2;
    position: relative;
    animation: fadeUp 0.8s cubic-bezier(0.25, 0.8, 0.25, 1) 0.2s both;
  }
  .hero-img-wrap {
    position: relative;
    width: clamp(280px, 35vw, 400px);
    height: clamp(280px, 35vw, 400px);
    border-radius: 50%;
    border: 2px solid var(--card-border);
    padding: 10px;
    background: var(--card);
    box-shadow: var(--shadow);
    transition: var(--transition);
  }
  .hero-img-wrap:hover {
    border-color: var(--accent);
    box-shadow: var(--accent-glow) 0 0 40px;
    transform: scale(1.02);
  }
  .hero-img-wrap img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* SECTIONS */
  section {
    padding: 6.5rem clamp(1.5rem, 6vw, 6rem);
    position: relative;
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    display: inline-block;
  }
  .section-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .section-title em {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: normal;
  }
  .section-sub { color: var(--text-muted); max-width: 580px; margin-bottom: 3.5rem; font-size: 1.05rem; }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: 4rem;
    align-items: center;
  }
  .about-content { display: flex; flex-direction: column; gap: 1.5rem; }
  .about-para { color: var(--text-muted); line-height: 1.8; font-size: 1.05rem; }
  .about-highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .about-highlight-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    padding: 1.5rem;
    border-radius: 16px;
    box-shadow: var(--shadow);
    transition: var(--transition);
  }
  .about-highlight-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .about-highlight-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .about-highlight-title {
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
    color: var(--text);
  }
  .about-highlight-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  /* Academic Gauges (Radial indicators) */
  .academic-gauges {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 3rem 2rem;
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }
  .gauge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .radial-progress {
    position: relative;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: conic-gradient(var(--accent) 0%, var(--accent-secondary) var(--percent), var(--timeline-line) var(--percent));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .radial-progress::before {
    content: "";
    position: absolute;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--card);
  }
  .radial-val {
    position: relative;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text);
  }
  .radial-label {
    text-align: center;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }
  .radial-sublabel {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* SKILLS */
  .skills-bg {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 32px;
    padding: 4rem clamp(1.5rem, 5vw, 4rem);
    box-shadow: var(--shadow);
    backdrop-filter: blur(12px);
  }
  .skills-tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .skills-tab-btn {
    background: var(--bg-accent);
    border: 1px solid var(--card-border);
    padding: 0.6rem 1.5rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--text-muted);
    transition: var(--transition);
  }
  .skills-tab-btn.active, .skills-tab-btn:hover {
    background: var(--accent-gradient);
    color: #fff;
    border-color: transparent;
  }
  .skills-grid-container {
    display: none;
  }
  .skills-grid-container.active {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    animation: fadeIn 0.5s ease both;
  }
  .skill-card {
    background: var(--bg-accent);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    padding: 1.5rem;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .skill-card:hover {
    transform: translateY(-4px) scale(1.01);
    border-color: var(--accent);
    box-shadow: var(--shadow);
    background: var(--card);
  }
  .skill-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .skill-icon {
    font-size: 1.75rem;
  }
  .skill-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text);
  }
  .skill-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  /* EXPERIENCE TIMELINE */
  .timeline-container {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 0;
  }
  .timeline-container::before {
    content: '';
    position: absolute;
    left: 20px; top: 0; bottom: 0;
    width: 2px;
    background: var(--timeline-line);
  }
  .timeline-item {
    position: relative;
    padding-left: 55px;
    margin-bottom: 3.5rem;
  }
  .timeline-item:last-child { margin-bottom: 0; }
  
  .timeline-dot {
    position: absolute;
    left: 11px; top: 6px;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--accent);
    border: 4px solid var(--bg);
    box-shadow: 0 0 12px var(--accent);
    z-index: 2;
    transition: var(--transition);
  }
  .timeline-item:hover .timeline-dot {
    transform: scale(1.3);
    background: var(--accent-secondary);
  }
  
  .timeline-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: var(--shadow);
    transition: var(--transition);
  }
  .timeline-card:hover {
    transform: translateX(6px);
    border-color: var(--accent);
  }
  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .timeline-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
  }
  .timeline-company {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .timeline-date {
    font-size: 0.8rem;
    background: var(--bg-accent);
    color: var(--text-muted);
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 600;
  }
  .timeline-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  /* PROJECTS */
  .projects-filter {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
    justify-content: flex-start;
    flex-wrap: wrap;
  }
  .projects-filter-btn {
    background: var(--card);
    border: 1px solid var(--card-border);
    padding: 0.6rem 1.5rem;
    border-radius: 30px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--text-muted);
    transition: var(--transition);
    box-shadow: var(--shadow);
  }
  .projects-filter-btn.active, .projects-filter-btn:hover {
    background: var(--accent-gradient);
    color: #fff;
    border-color: transparent;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  .proj-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 2.25rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .proj-card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow: var(--glow), var(--shadow);
  }
  .proj-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: var(--accent-gradient);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .proj-card:hover::after { transform: scaleX(1); }
  
  .proj-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .proj-num {
    font-size: 2.75rem;
    font-weight: 800;
    opacity: 0.15;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .proj-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
  }
  .proj-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    flex-grow: 1;
  }
  .proj-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .proj-tag {
    font-size: 0.75rem;
    background: var(--bg-accent);
    color: var(--text-muted);
    padding: 4px 12px;
    border-radius: 30px;
    font-weight: 600;
    border: 1px solid var(--card-border);
  }

  /* CERTIFICATIONS */
  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .cert-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    padding: 1.5rem 1.75rem;
    display: flex; align-items: center; gap: 1.25rem;
    box-shadow: var(--shadow);
    transition: var(--transition);
  }
  .cert-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .cert-icon-box {
    width: 48px; height: 48px;
    background: var(--bg-accent);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
    border: 1px solid var(--card-border);
    transition: var(--transition);
  }
  .cert-card:hover .cert-icon-box {
    background: var(--accent-gradient);
    color: #fff;
  }
  .cert-name { font-size: 0.95rem; font-weight: 700; color: var(--text); line-height: 1.4; }
  .cert-org { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem; }

  /* EDUCATION */
  .edu-cards { display: flex; flex-direction: column; gap: 1.5rem; }
  .edu-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
